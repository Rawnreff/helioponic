# =============================================================================
# Helioponic — Environment Variables Example
# =============================================================================
# Copy this file to the appropriate location and fill in your values:
#
#   cp .env.example helioponic-backend/.env        # Backend config
#   cp .env.example helioponic-mobile/.env          # Mobile app config
#
# For Docker Compose, variables are set directly in docker-compose.yml.
# =============================================================================

# =============================================================================
# BACKEND CONFIGURATION (.env di helioponic-backend/)
# =============================================================================

# --- Server ---
SERVER_PORT=8080
GIN_MODE=debug              # debug | release | test
LOG_LEVEL=info              # debug | info | warn | error

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=helioponic
DB_PASSWORD=helioponic123   # Ganti dengan password yang aman
DB_NAME=helioponic
DB_SSLMODE=disable          # enable | disable | require

# --- MQTT (Mosquitto Broker) ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=helioponic_backend
MQTT_USERNAME=              # Kosongkan jika tidak pakai auth MQTT
MQTT_PASSWORD=              # Kosongkan jika tidak pakai auth MQTT

# --- JWT ---
JWT_SECRET=change-me-in-production   # Ganti dengan secret yang kuat!


# =============================================================================
# MOBILE APP CONFIGURATION (.env di helioponic-mobile/)
# =============================================================================
#
# Catatan: Untuk Flutter, .env tidak dibaca otomatis. Ubah nilai default
# di lib/core/constants.dart langsung, atau gunakan package flutter_dotenv.
#
# API_BASE_URL=http://192.168.2.73:8080/api/v1
# WS_URL=ws://192.168.2.73:8080/ws/pid
