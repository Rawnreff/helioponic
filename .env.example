# =============================================================================
# Helioponic — Environment Variables Example
# =============================================================================
# Copy this file to the appropriate location and fill in your values:
#
#   cp .env.example helioponic-backend/.env        # Backend config
#   cp .env.example helioponic-mobile/.env          # Mobile app config
#
# For Docker Compose, variables are set directly in docker-compose.yml.
# =============================================================================

# =============================================================================
# BACKEND CONFIGURATION (.env in helioponic-backend/)
# =============================================================================

# --- Server ---
SERVER_PORT=8080
LOG_LEVEL=info              # debug | info | warn | error

# --- MongoDB (motor async driver) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helioponic

# --- MQTT (Mosquitto Broker) — with authentication ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=helioponic_backend
MQTT_USERNAME=helioponic
MQTT_PASSWORD=helioponic_mqtt_2024

# --- JWT ---
JWT_SECRET=change-me-in-production   # Ganti dengan secret yang kuat!
JWT_EXPIRATION_HOURS=72

# =============================================================================
# FIRMWARE CONFIGURATION (hardcoded in .ino files)
# =============================================================================
# Update these in helioponic-firmware/esp32/helioponic_esp32.ino:
#   - WIFI_SSID / WIFI_PASSWORD
#   - MQTT_BROKER (ESP32 needs the broker's LAN IP, not "localhost")
#   - MQTT_USERNAME / MQTT_PASSWORD (must match broker credentials)


# =============================================================================
# MOBILE APP CONFIGURATION (.env in helioponic-mobile/)
# =============================================================================
#
# API_BASE_URL=http://192.168.1.100:8080/api/v1
# WS_URL=ws://192.168.1.100:8080/ws/pid
