// =============================================================================
// Helioponic — ESP32 WiFi & MQTT Secrets (Template)
// =============================================================================
//
// Copy this file to secrets.h and fill in your credentials:
//
//   cp secrets.h.example secrets.h
//
// The secrets.h file is gitignored (see root .gitignore) so your
// credentials are never committed to version control.
//
// Note: config.h has been merged directly into helioponic_esp32.ino.
// All hardware configuration (pins, calibration, thresholds, MQTT topics)
// is now defined at the top of the .ino file — no need for a separate config.h.
//
// WiFi & MQTT credentials remain here in secrets.h for safety.
// =============================================================================
#ifndef SECRETS_H
#define SECRETS_H

// ---- WiFi Credentials (REQUIRED) ----
// The ESP32 connects to your local WiFi network.
#define WIFI_SSID      "YourWiFiSSID"
#define WIFI_PASSWORD  "YourWiFiPassword"

// ---- MQTT Broker (REQUIRED for physical ESP32 deployment) ----
// The .ino file defaults MQTT_BROKER to "localhost", which only works
// when the ESP32 is connected via serial monitor on the same machine.
// For physical deployment, uncomment and set your broker's LAN address:
// #define MQTT_BROKER  "192.168.1.100"

// ---- MQTT Authentication (OPTIONAL) ----
// Leave empty strings for anonymous connections.
#define MQTT_USER      ""
#define MQTT_PASS      ""

#endif // SECRETS_H
