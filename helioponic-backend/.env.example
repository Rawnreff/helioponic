# =============================================================================
# Helioponic Backend — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads these from docker-compose.yml directly.
# =============================================================================

# ---- Server ----
SERVER_PORT=8080
LOG_LEVEL=info

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helioponic

# ---- MQTT (Mosquitto Broker) — with authentication ----
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=helioponic_backend
MQTT_USERNAME=helioponic
MQTT_PASSWORD=helioponic_mqtt_2024

# ---- JWT Authentication ----
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=72
