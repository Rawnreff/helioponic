# =============================================================================
# Helioponic Backend — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The backend loads these values via helioponic-backend/internal/config/config.go
# Docker Compose reads from ./helioponic-backend/.env (see docker-compose.yml)
# =============================================================================

# ---- Server ----
SERVER_PORT=8080
GIN_MODE=debug
LOG_LEVEL=info

# ---- PostgreSQL Database ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=helioponic
DB_PASSWORD=helioponic123
DB_NAME=helioponic
DB_SSLMODE=disable

# ---- MQTT Broker (Mosquitto) ----
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=helioponic_backend
MQTT_USERNAME=
MQTT_PASSWORD=

# ---- JWT Authentication ----
JWT_SECRET=change-me-in-production
