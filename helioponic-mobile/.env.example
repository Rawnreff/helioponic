# =============================================================================
# Helioponic Mobile — Environment Variables (Template)
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# The .env file is gitignored — never commit real credentials.
#
# These values are loaded by babel-plugin-inline-dotenv and override
# the defaults in src/constants.ts.
#
# Platform defaults (if env vars are not set):
#   Android emulator: http://10.0.2.2:8000/api/v1
#   iOS simulator:    http://localhost:8000/api/v1
# =============================================================================

# ---- Backend API URL ----
API_URL=http://localhost:8000/api/v1

# ---- WebSocket URL ----
WS_URL=ws://localhost:8000/ws/pid
